# Токен Telegram-бота от @BotFather
BOT_TOKEN=

# Дефолтный (общий) ключ OpenRouter — используется, если юзер не задал свой
OPENROUTER_API_KEY=

# Секрет для шифрования данных в БД (ключи пользователей, тексты сообщений).
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
# ВАЖНО: при смене этого секрета все ранее зашифрованные данные станут нечитаемы.
ENCRYPTION_KEY=

# --- необязательные ---
# Путь к файлу БД SQLite
DB_PATH=orbot.db
# Через сколько часов обновлять кэш списка free-моделей
MODELS_CACHE_TTL_HOURS=6
# Сколько последних сообщений отправлять модели
HISTORY_MAX_MESSAGES=20
# Модель по умолчанию для новых чатов
DEFAULT_MODEL=deepseek/deepseek-r1:free
